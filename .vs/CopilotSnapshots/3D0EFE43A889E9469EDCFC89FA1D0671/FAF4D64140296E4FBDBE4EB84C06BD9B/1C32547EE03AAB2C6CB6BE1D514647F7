using Newtonsoft.Json.Linq;
using System;
using System.IO;

namespace client_firebase
{
    public static class AppConfig
    {
        public static string FirebaseApiKey { get; private set; }
        public static string FirebaseDatabaseUrl { get; private set; }
        public static string GoogleClientId { get; private set; }
        public static string GoogleClientSecret { get; private set; }
        public static string FacebookAppId { get; private set; }
        public static string FacebookClientSecret { get; private set; }

        public static void LoadConfig()
        {
            try
            {
                string jsonText = File.ReadAllText("config.json");
                JObject config = JObject.Parse(jsonText);

                FirebaseApiKey = config["FirebaseApiKey"]?.ToString();
                FirebaseDatabaseUrl = config["FirebaseDatabaseUrl"]?.ToString();
                GoogleClientId = config["GoogleClientId"]?.ToString();
                GoogleClientSecret = config["GoogleClientSecret"]?.ToString();
                FacebookAppId = config["FacebookAppId"]?.ToString();
                FacebookClientSecret = config["FacebookClientSecret"]?.ToString();
            }
            catch (Exception ex)
            {
                System.Windows.Forms.MessageBox.Show("Lỗi đọc file cấu hình: " + ex.Message, "Lỗi nghiêm trọng");
            }
        }
    }
}